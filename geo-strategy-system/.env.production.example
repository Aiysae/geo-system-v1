# 生产环境变量模板 — 复制到服务器上一级目录并重命名为 .env.production
# 路径示例：/var/www/geo-strategy-system/.env.production
# 切勿将填好真实密钥的文件提交到 Git

# ── Clerk（生产环境请使用 Live 密钥 pk_live_ / sk_live_）──
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxx
CLERK_SECRET_KEY=sk_live_xxxxxxxx

# ── Vercel KV / Upstash（积分与充值，阿里云 ECS 上可继续使用）──
KV_REST_API_URL=https://xxxxx.upstash.io
KV_REST_API_TOKEN=xxxxxxxx
KV_REST_API_READ_ONLY_TOKEN=xxxxxxxx
KV_URL=rediss://default:xxxxx@xxxxx.upstash.io:6379
REDIS_URL=rediss://default:xxxxx@xxxxx.upstash.io:6379

# ── DeepSeek ──
DEEPSEEK_API_KEY=sk-xxxxxxxx

# ── 火山方舟 / 豆包 ──
ARK_API_KEY=xxxxxxxx
ARK_DOUBAO_ENDPOINT_ID=ep-xxxxxxxx
ARK_DOUBAO_BOT_ID=bot-xxxxxxxx

# ── 通义千问（DashScope）──
DASHSCOPE_API_KEY=sk-xxxxxxxx
DASHSCOPE_MODEL=qwen-plus

# ── Kimi（Moonshot）──
MOONSHOT_API_KEY=sk-xxxxxxxx
MOONSHOT_MODEL=moonshot-v1-8k
