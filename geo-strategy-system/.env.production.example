# 生产环境变量模板 — 复制到服务器上一级目录并重命名为 .env.production
# 路径示例：/var/www/geo-strategy-system/.env.production
# 切勿将填好真实密钥的文件提交到 Git

# ── 本地账号 / Session ──
# 生成方式：openssl rand -base64 32
AUTH_SECRET=xxxxxxxx
# 管理员邮箱，多个用英文逗号分隔；这些邮箱注册/登录后可访问 /admin
ADMIN_EMAILS=admin@example.com

# ── Vercel KV / Upstash（积分与充值，阿里云 ECS 上可继续使用）──
KV_REST_API_URL=https://xxxxx.upstash.io
KV_REST_API_TOKEN=xxxxxxxx
KV_REST_API_READ_ONLY_TOKEN=xxxxxxxx
KV_URL=rediss://default:xxxxx@xxxxx.upstash.io:6379
REDIS_URL=rediss://default:xxxxx@xxxxx.upstash.io:6379

# ── DeepSeek ──
DEEPSEEK_API_KEY=sk-xxxxxxxx

# ── 火山方舟 / 豆包 ──
ARK_API_KEY=xxxxxxxx
ARK_DOUBAO_ENDPOINT_ID=ep-xxxxxxxx
ARK_DOUBAO_BOT_ID=bot-xxxxxxxx

# ── 通义千问（DashScope）──
DASHSCOPE_API_KEY=sk-xxxxxxxx
DASHSCOPE_MODEL=qwen-plus

# ── Kimi（Moonshot）──
MOONSHOT_API_KEY=sk-xxxxxxxx
MOONSHOT_MODEL=moonshot-v1-8k

# ── 百度千帆 / 文心一言（V2 OpenAI 兼容接口）──
BAIDU_QIANFAN_API_KEY=bce-v3/xxxxxxxx
BAIDU_QIANFAN_MODEL=ernie-4.5-turbo-32k
BAIDU_QIANFAN_CHAT_URL=https://qianfan.baidubce.com/v2/chat/completions
# 可选：如果你的千帆应用要求 appid 头，填 app-xxxxxxxx
BAIDU_QIANFAN_APP_ID=
# 若所选模型不支持联网搜索，可设为 false
BAIDU_QIANFAN_ENABLE_SEARCH=true

# ── 腾讯元宝 / 混元（OpenAI 兼容接口）──
TENCENT_HUNYUAN_API_KEY=sk-xxxxxxxx
TENCENT_HUNYUAN_MODEL=hunyuan-turbos-latest
TENCENT_HUNYUAN_CHAT_URL=https://api.hunyuan.cloud.tencent.com/v1/chat/completions
# 仅确认当前混元模型/端点支持增强参数时再开启
TENCENT_HUNYUAN_ENABLE_ENHANCEMENT=false
